APP_ENV=dev

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=harness_kanban
POSTGRES_PASSWORD=harness_kanban
POSTGRES_DB=harness_kanban_dev

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_ROOT_USER=harness-kanban
MINIO_ROOT_PASSWORD=harness-kanban-minio-secret
MINIO_BUCKET=harness-kanban-uploads-dev

API_PORT=3001
WEB_PORT=3000
STORYBOOK_PORT=6006

APP_BASE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=harness-kanban-devcontainer-auth-secret
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_SERVER_URL=http://localhost:3001

AI_PROVIDER=openai
OPENAI_API_KEY=sk-harness-kanban-devcontainer-placeholder
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_OPENAI_API_KEY=sk-harness-kanban-devcontainer-placeholder
EMBEDDING_OPENAI_MODEL=text-embedding-3-small
