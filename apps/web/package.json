{
  "name": "@harness-kanban/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env -- sh -c 'NEXT_DIST_MODE=dev next dev -p ${PORT:-3000}'",
    "start": "cross-env NEXT_DIST_MODE=build next start",
    "build": "cross-env NEXT_DIST_MODE=build next build",
    "build:lib": "tsc -p tsconfig.lib.json",
    "lint": "eslint . --fix --ext js,jsx,ts,tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\" \"*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:storybook": "dotenv -e .env -- sh -c 'test-storybook --url http://127.0.0.1:${STORYBOOK_PORT:-6006}'",
    "test:e2e": "playwright test",
    "storybook": "cross-env NODE_ENV=development dotenv -e .env -- sh -c 'storybook dev -p ${STORYBOOK_PORT}'",
    "storybook-alive": "dotenv -e .env -- sh -c 'curl -s -o /dev/null -w \"%{http_code}\" http://localhost:${STORYBOOK_PORT:-6006} | grep -q \"200\" && echo \"Storybook is running\" || echo \"Storybook is not running\"'",
    "build-storybook": "storybook build"
  },
