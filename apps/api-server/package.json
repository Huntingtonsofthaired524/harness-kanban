{
  "name": "@harness-kanban/api-server",
  "version": "0.0.1",
  "private": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "dev:worker": "dotenv -o -e .env.worker -- nest start --watch --entryFile worker-main",
    "start:worker": "node dist/worker-main.js",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:e2e": "dotenv -e .env.e2e -- pnpm --filter @repo/database db:migrate && dotenv -e .env.e2e -- jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^1.0.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/assemblyai": "^1.0.0",
    "@ai-sdk/azure": "^1.0.0",
    "@ai-sdk/baseten": "^1.0.0",
    "@ai-sdk/black-forest-labs": "^1.0.0",
    "@ai-sdk/cerebras": "^1.0.0",
    "@ai-sdk/cohere": "^1.0.0",
    "@ai-sdk/deepgram": "^1.0.0",
    "@ai-sdk/deepinfra": "^1.0.0",
    "@ai-sdk/deepseek": "^1.0.0",
    "@ai-sdk/elevenlabs": "^1.0.0",
    "@ai-sdk/fal": "^1.0.0",
    "@ai-sdk/fireworks": "^1.0.0",
    "@ai-sdk/gladia": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/google-vertex": "^1.0.0",
    "@ai-sdk/groq": "^1.0.0",
    "@ai-sdk/huggingface": "^1.0.0",
    "@ai-sdk/hume": "^1.0.0",
    "@ai-sdk/lmnt": "^1.0.0",
    "@ai-sdk/luma": "^1.0.0",
    "@ai-sdk/mistral": "^1.0.0",
    "@ai-sdk/moonshotai": "^2.0.1",
    "@ai-sdk/open-responses": "^1.0.0",
    "@ai-sdk/openai": "^3.0.21",
    "@ai-sdk/perplexity": "^1.0.0",
    "@ai-sdk/prodia": "^1.0.0",
    "@ai-sdk/replicate": "^1.0.0",
    "@ai-sdk/revai": "^1.0.0",
    "@ai-sdk/togetherai": "^1.0.0",
    "@ai-sdk/xai": "^1.0.0",
    "@chroma-core/openai": "^0.1.9",
    "@langchain/core": "^1.1.17",
    "@langchain/langgraph": "^1.1.2",
    "@langchain/openai": "^1.2.3",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/websockets": "^11.1.6",
    "@repo/database": "workspace:*",
    "@repo/shared": "workspace:*",
    "@thallesp/nestjs-better-auth": "^2.2.2",
    "@tiptap/core": "3.0.7",
    "ai": "^6.0.59",
    "bash-tool": "^1.3.14",
    "better-auth": "^1.4.16",
    "chalk": "4.1.2",
    "chromadb": "^3.3.1",
    "date-fns": "^4.1.0",
    "just-bash": "^2.10.0",
    "langchain": "^1.2.14",
    "prosemirror-markdown": "^1.13.2",
    "prosemirror-model": "^1.25.2",
    "prisma": "^6.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "vitest": "3.2.3",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@langchain/langgraph-cli": "^1.1.11",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.5",
    "@repo/config": "workspace:*",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/passport": "^1.0.17",
    "@types/supertest": "^6.0.2",
    "babel-jest": "^30.2.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(bash-tool|just-bash)/)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@repo/database$": "<rootDir>/../../../packages/database/src/index.ts",
      "^@repo/database/(.*)$": "<rootDir>/../../../packages/database/src/$1",
      "^@repo/shared$": "<rootDir>/../../../packages/shared/src/index.ts",
      "^@repo/shared/(.*)$": "<rootDir>/../../../packages/shared/src/$1",
      "^bash-tool$": "<rootDir>/test/mocks/bash-tool.mock.ts"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/*.test.ts",
      "!**/*.d.ts",
      "!**/test/**",
      "!**/mocks/**",
      "!**/__tests__/**",
      "!main.ts",
      "!**/node_modules/**"
    ],
    "coverageDirectory": "<rootDir>/../coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testEnvironment": "node"
  }
}
