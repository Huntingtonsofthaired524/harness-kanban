DATABASE_URL=postgresql://postgres:postgrestemppassword@postgres:5432/harness_kanban
NODE_ENV=production

HARNESS_WORKER_TOOLCHAIN_STORE_DIR=/opt/harness-kanban/toolchains
HARNESS_WORKER_CODEX_TOOLCHAIN_VERSION=0.116.0
HARNESS_WORKER_CLAUDE_CODE_TOOLCHAIN_VERSION=2.1.92
HARNESS_WORKER_GIT_COMMIT_NAME=CodeBot
HARNESS_WORKER_GIT_COMMIT_EMAIL=bot_code_bot@harness-kanban.local
HARNESS_WORKER_CODING_AGENT_TIMEOUT_MS=1800000
HARNESS_WORKER_CODING_AGENT_OUTPUT_REPAIR_ATTEMPTS=2
HARNESS_WORKER_IMPLEMENTATION_REVIEW_REPAIR_ATTEMPTS=2
HARNESS_WORKER_HEARTBEAT_INTERVAL_MS=10000
HARNESS_WORKER_POLL_INTERVAL_MS=5000
HARNESS_WORKER_STALE_TIMEOUT_MS=60000
HARNESS_WORKER_GITHUB_READINESS_POLL_INTERVAL_MS=15000
HARNESS_WORKER_GITHUB_READINESS_TIMEOUT_MS=1800000
