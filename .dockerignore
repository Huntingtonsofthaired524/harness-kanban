# .dockerignore (place this in monorepo root)

# Node.js
node_modules
**/node_modules
.pnpm-store/
.pnpm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# Git
.git
.gitignore

# Documentation
*.md
docs/
README*

# Development files
.env
.env.*
!.env.example

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Build outputs (keep only what we need for specific apps)
dist/
build/
out/
.next/
.next-build/
**/.next/
**/.next-build/
coverage/
storybook-static/

# Logs
logs/
*.log

# Cache directories
.cache/
.parcel-cache/
.turbo/
**/.turbo/

# Testing
__tests__/
*.test.js
*.test.ts
*.spec.js
*.spec.ts

# Temporary files
.tmp/
temp/

# Docker
Dockerfile*
.dockerignore
docker-compose*.yml

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Other apps' build outputs (if you only need api-server)
apps/*/dist
packages/*/dist
packages/*/generated
# !apps/api-server/dist

# Exclude other apps entirely if they're not dependencies
# apps/web
# apps/mobile
